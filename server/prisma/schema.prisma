// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lottery {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  totalNumbers Int
  gameNumbers  Int
  
  // Novos campos para resiliência e painel
  nextPrize    Float?
  nextDate     DateTime?
  accumulated  Boolean  @default(false)

  
  results    Result[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Result {
  id        String   @id @default(uuid())
  lotteryId String
  lottery   Lottery  @relation(fields: [lotteryId], references: [id])
  
  contestNumber Int
  date          DateTime
  numbers       Int[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([lotteryId, contestNumber])
}

model SavedTicket {
  id            String   @id @default(uuid())
  lotterySlug   String
  contestNumber Int?     // Concurso vinculado a aposta, se souber
  numbers       Int[]    // Vetor de dezenas escolhidas
  cost          Float    @default(0.0)
  
  // Bolão Data
  isSyndicate   Boolean  @default(false)
  archived      Boolean  @default(false)   // true = aposta arquivada (já jogada)
  
  participants  Participant[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Participant {
  id            String      @id @default(uuid())
  name          String
  quota         Float
  savedTicketId String
  savedTicket   SavedTicket @relation(fields: [savedTicketId], references: [id], onDelete: Cascade)
}
